# ============================================================
# VARIABLES DE ENTORNO — BACKEND
# Copia este archivo como .env y llena los valores
# ============================================================

# PostgreSQL — Railway te da esto automáticamente
DATABASE_URL=postgresql://usuario:contraseña@host:5432/nombre_db

# JWT — Genera una cadena larga y aleatoria (mínimo 64 caracteres)
# Puedes generar una en: https://generate-secret.vercel.app/64
JWT_SECRET=cambia_esto_por_una_cadena_muy_larga_y_secreta

# Entorno
NODE_ENV=production
PORT=3000

# URL del frontend (para CORS)
# En Railway, pon la URL de tu servicio de frontend
FRONTEND_URL=https://tu-erp.up.railway.app

# Email para envío de Órdenes de Compra (opcional)
# Si no lo configuras, el envío se simula en los logs
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=tu_api_key_aqui
EMAIL_FROM=erp@tuempresa.com
EMAIL_FROM_NAME=Sistema ERP
